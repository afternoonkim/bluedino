"use client";

import { useMemo, useRef, useState } from "react";
import {
  Bar,
  BarChart,
  CartesianGrid,
  Legend,
  ResponsiveContainer,
  Tooltip,
  XAxis,
  YAxis,
} from "recharts";
import * as htmlToImage from "html-to-image";


type TimingMode = "end" | "start";

type YearPoint = {
  year: number;
  age: number;
  principal: number;
  profit: number;
  total: number;
  realTotal: number;
};

const quickMonthlyAmounts = [300000, 500000, 1000000, 2000000, 3000000, 5000000];
const referenceReturns = [4, 6, 8, 10, 12, 15];
const referenceYears = [5, 10, 15, 20, 25, 30, 40, 50];

function formatNumber(value: number) {
  return Math.round(value).toLocaleString("ko-KR");
}

function formatMoney(value: number) {
  if (value >= 100000000) {
    return `${(value / 100000000).toFixed(value >= 1000000000 ? 0 : 1)}억`;
  }
  if (value >= 10000) {
    return `${(value / 10000).toFixed(0)}만`;
  }
  return `${Math.round(value).toLocaleString("ko-KR")}원`;
}

function unformat(value: string) {
  return Number(String(value).replace(/,/g, "")) || 0;
}

function withComma(value: string) {
  const digits = value.replace(/[^0-9]/g, "");
  if (!digits) return "";
  return Number(digits).toLocaleString("ko-KR");
}

function simulateCompound(params: {
  initialAsset: number;
  monthlyContribution: number;
  annualReturn: number;
  annualIncrease: number;
  years: number;
  currentAge: number;
  inflation: number;
  timing: TimingMode;
}) {
  const {
    initialAsset,
    monthlyContribution,
    annualReturn,
    annualIncrease,
    years,
    currentAge,
    inflation,
    timing,
  } = params;

  const monthlyReturn = annualReturn / 100 / 12;
  const yearlyInflation = inflation / 100;

  let balance = initialAsset;
  let totalPrincipal = initialAsset;
  let currentMonthly = monthlyContribution;

  const rows: YearPoint[] = [];

  for (let year = 1; year <= years; year++) {
    for (let month = 0; month < 12; month++) {
      if (timing === "start") {
        balance += currentMonthly;
        totalPrincipal += currentMonthly;
        balance *= 1 + monthlyReturn;
      } else {
        balance *= 1 + monthlyReturn;
        balance += currentMonthly;
        totalPrincipal += currentMonthly;
      }
    }

    const inflationFactor = Math.pow(1 + yearlyInflation, year);
    const realTotal = balance / inflationFactor;

    rows.push({
      year,
      age: currentAge + year,
      principal: Math.round(totalPrincipal),
      profit: Math.round(balance - totalPrincipal),
      total: Math.round(balance),
      realTotal: Math.round(realTotal),
    });

    currentMonthly *= 1 + annualIncrease / 100;
  }

  return rows;
}

function buildReferenceValue(monthly: number, annualReturn: number, years: number) {
  const rows = simulateCompound({
    initialAsset: 0,
    monthlyContribution: monthly,
    annualReturn,
    annualIncrease: 0,
    years,
    currentAge: 0,
    inflation: 0,
    timing: "end",
  });
  return rows[rows.length - 1]?.total ?? 0;
}

export default function CompoundCalculatorPage() {
  const [initialAsset, setInitialAsset] = useState("10,000,000");
  const [monthlyContribution, setMonthlyContribution] = useState("1,000,000");
  const [annualReturn, setAnnualReturn] = useState(8);
  const [annualIncrease, setAnnualIncrease] = useState(2.5);
  const [years, setYears] = useState(30);
  const [currentAge, setCurrentAge] = useState(30);
  const [targetAsset, setTargetAsset] = useState("1,000,000,000");
  const [inflation, setInflation] = useState(2.5);
  const [timing, setTiming] = useState<TimingMode>("end");
  const [useRealValue, setUseRealValue] = useState(false);

  const captureRef = useRef<HTMLDivElement>(null);

  const simulation = useMemo(() => {
    return simulateCompound({
      initialAsset: unformat(initialAsset),
      monthlyContribution: unformat(monthlyContribution),
      annualReturn,
      annualIncrease,
      years,
      currentAge,
      inflation,
      timing,
    });
  }, [initialAsset, monthlyContribution, annualReturn, annualIncrease, years, currentAge, inflation, timing]);

  const summary = useMemo(() => {
    const finalRow = simulation[simulation.length - 1];
    const target = unformat(targetAsset);
    const targetYear = simulation.find((row) => row.total >= target || row.realTotal >= target);

    return {
      finalTotal: finalRow?.total ?? 0,
      finalRealTotal: finalRow?.realTotal ?? 0,
      totalPrincipal: finalRow?.principal ?? 0,
      totalProfit: finalRow?.profit ?? 0,
      multiple:
        (finalRow?.principal ?? 0) > 0
          ? (finalRow?.total ?? 0) / (finalRow?.principal ?? 1)
          : 0,
      targetYear,
    };
  }, [simulation, targetAsset]);

  const chartData = useMemo(() => {
    return simulation.map((row) => ({
      year: `${row.year}년`,
      age: row.age,
      원금: row.principal,
      수익: row.profit,
      실질자산: row.realTotal,
      총자산: row.total,
    }));
  }, [simulation]);

  const referenceTable = useMemo(() => {
    return referenceYears.map((year) => {
      const row: Record<string, string | number> = { year };
      referenceReturns.forEach((rate) => {
        row[`r${rate}`] = formatMoney(buildReferenceValue(1000000, rate, year));
      });
      return row;
    });
  }, []);

  const handleSaveImage = async () => {
    if (!captureRef.current) return;
    try {
      const dataUrl = await htmlToImage.toPng(captureRef.current, {
        cacheBust: true,
        pixelRatio: 2,
        backgroundColor: "#081121",
      });
      const link = document.createElement("a");
      link.download = "bluedino-compound-result.png";
      link.href = dataUrl;
      link.click();
    } catch (error) {
      console.error(error);
      alert("이미지 저장에 실패했습니다.");
    }
  };

  return (
    <main className="min-h-screen bg-[#f4f7fb] px-4 py-6 text-slate-900 md:px-6">
      <div className="mx-auto max-w-7xl">
        <div className="mb-6">
          <p className="text-sm font-semibold text-blue-600">BlueDino 계산기</p>
          <h1 className="mt-2 text-2xl font-bold tracking-tight text-slate-900 md:text-3xl">
            복리 계산기
          </h1>
          <p className="mt-2 text-sm leading-6 text-slate-500 md:text-base">
            월 적립금, 수익률, 투자기간을 넣으면 장기 복리 효과를 한눈에 확인할 수 있습니다.
            BlueDino 스타일에 맞춰 왼쪽 입력 카드, 오른쪽 결과 카드 구조로 정리했습니다.
          </p>
        </div>

        <div className="grid gap-6 xl:grid-cols-[340px_minmax(0,1fr)]">
          <section className="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <div className="flex items-center justify-between">
              <h2 className="text-base font-bold text-slate-900">복리 투자 설정</h2>
              <span className="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-600">
                입력 카드
              </span>
            </div>

            <div className="mt-5 grid gap-3">
              <InputCard
                label="현재 자산"
                value={initialAsset}
                onChange={(v) => setInitialAsset(withComma(v))}
                suffix="원"
              />
              <InputCard
                label="월 투자금"
                value={monthlyContribution}
                onChange={(v) => setMonthlyContribution(withComma(v))}
                suffix="원"
              />

              <RangeCard
                label="연간 목표 수익률"
                value={annualReturn}
                onChange={setAnnualReturn}
                min={1}
                max={20}
                step={0.5}
                suffix="%"
              />
              <RangeCard
                label="연 투자금 증가율"
                value={annualIncrease}
                onChange={setAnnualIncrease}
                min={0}
                max={20}
                step={0.5}
                suffix="%"
              />
              <RangeCard
                label="투자 기간"
                value={years}
                onChange={setYears}
                min={1}
                max={50}
                step={1}
                suffix="년"
              />
              <RangeCard
                label="현재 나이"
                value={currentAge}
                onChange={setCurrentAge}
                min={18}
                max={70}
                step={1}
                suffix="세"
              />
              <InputCard
                label="목표 자산"
                value={targetAsset}
                onChange={(v) => setTargetAsset(withComma(v))}
                suffix="원"
              />
              <RangeCard
                label="물가상승률"
                value={inflation}
                onChange={setInflation}
                min={0}
                max={10}
                step={0.1}
                suffix="%"
              />

              <div className="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
                <p className="text-xs font-semibold text-slate-500">납입 시점</p>
                <div className="mt-3 grid grid-cols-2 gap-2">
                  <button
                    type="button"
                    onClick={() => setTiming("end")}
                    className={`rounded-xl border px-3 py-2 text-sm font-semibold transition ${
                      timing === "end"
                        ? "border-blue-600 bg-blue-600 text-white"
                        : "border-slate-200 bg-white text-slate-700"
                    }`}
                  >
                    월말 납입
                  </button>
                  <button
                    type="button"
                    onClick={() => setTiming("start")}
                    className={`rounded-xl border px-3 py-2 text-sm font-semibold transition ${
                      timing === "start"
                        ? "border-blue-600 bg-blue-600 text-white"
                        : "border-slate-200 bg-white text-slate-700"
                    }`}
                  >
                    월초 납입
                  </button>
                </div>
              </div>

              <div className="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
                <div className="flex items-center justify-between gap-3">
                  <div>
                    <p className="text-xs font-semibold text-slate-500">실질가치 보기</p>
                    <p className="mt-1 text-xs text-slate-400">물가상승률을 반영한 자산도 함께 확인</p>
                  </div>
                  <button
                    type="button"
                    role="switch"
                    aria-checked={useRealValue}
                    onClick={() => setUseRealValue((prev) => !prev)}
                    className={`relative h-7 w-12 rounded-full transition ${
                      useRealValue ? "bg-blue-600" : "bg-slate-300"
                    }`}
                  >
                    <span
                      className={`absolute top-1 h-5 w-5 rounded-full bg-white transition ${
                        useRealValue ? "left-6" : "left-1"
                      }`}
                    />
                  </button>
                </div>
              </div>

              <button
                type="button"
                onClick={handleSaveImage}
                className="mt-1 rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-bold text-blue-700 transition hover:bg-blue-100"
              >
                결과 이미지 저장하기
              </button>
            </div>
          </section>

          <div ref={captureRef} className="grid gap-6">
            <section className="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
              <div className="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                  <h2 className="text-base font-bold text-slate-900">분석 결과</h2>
                  <p className="mt-1 text-sm text-slate-500">
                    {years}년 투자 기준 예상 결과입니다.
                  </p>
                </div>
                <div className="rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                  종료 나이 <span className="font-bold text-slate-900">{currentAge + years}세</span>
                </div>
              </div>

              <div className="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
                <ResultCard title="최종 예상 자산" value={formatMoney(summary.finalTotal)} accent="blue" />
                <ResultCard title="실질 자산 가치" value={formatMoney(summary.finalRealTotal)} accent="indigo" />
                <ResultCard title="총 투자원금" value={formatMoney(summary.totalPrincipal)} accent="slate" />
                <ResultCard title="총 수익금" value={formatMoney(summary.totalProfit)} accent="green" />
                <ResultCard
                  title="수익 배수"
                  value={`${summary.multiple.toFixed(1)}배`}
                  accent="violet"
                />
              </div>

              <div className="mt-4 grid gap-4 xl:grid-cols-2">
                <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                  <p className="text-xs font-semibold text-slate-500">목표 자산 도달</p>
                  <p className="mt-2 text-lg font-bold text-slate-900">
                    {summary.targetYear
                      ? `${summary.targetYear.year}년 차 · ${summary.targetYear.age}세`
                      : "현재 조건으로는 투자 기간 내 미도달"}
                  </p>
                  <p className="mt-2 text-sm leading-6 text-slate-500">
                    목표 자산 {formatMoney(unformat(targetAsset))} 기준으로 계산했습니다.
                  </p>
                </div>

                <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                  <p className="text-xs font-semibold text-slate-500">현재 설정 요약</p>
                  <div className="mt-2 grid grid-cols-2 gap-3 text-sm text-slate-600">
                    <div>월 투자금</div>
                    <div className="text-right font-semibold text-slate-900">{formatMoney(unformat(monthlyContribution))}</div>
                    <div>연 수익률</div>
                    <div className="text-right font-semibold text-slate-900">{annualReturn}%</div>
                    <div>연 증가율</div>
                    <div className="text-right font-semibold text-slate-900">{annualIncrease}%</div>
                    <div>납입 시점</div>
                    <div className="text-right font-semibold text-slate-900">{timing === "start" ? "월초" : "월말"}</div>
                  </div>
                </div>
              </div>
            </section>

            <section className="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
              <div className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <h2 className="text-base font-bold text-slate-900">자산 성장 그래프</h2>
                  <p className="mt-1 text-sm text-slate-500">
                    원금과 수익이 시간이 지나며 어떻게 누적되는지 확인할 수 있습니다.
                  </p>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-600">
                  {useRealValue ? "실질가치 표시 중" : "명목가치 표시 중"}
                </div>
              </div>

              <div className="mt-5 h-[380px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart
                    data={chartData}
                    margin={{ top: 12, right: 16, left: 0, bottom: 8 }}
                  >
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#e5e7eb" />
                    <XAxis
                      dataKey="year"
                      tick={{ fontSize: 12, fill: "#64748b" }}
                      tickLine={false}
                      axisLine={false}
                    />
                    <YAxis
                      tickFormatter={(value) => formatMoney(Number(value))}
                      tick={{ fontSize: 12, fill: "#64748b" }}
                      tickLine={false}
                      axisLine={false}
                      width={72}
                    />
                    <Tooltip
                      formatter={(value: number, name: string) => [formatNumber(value) + "원", name]}
                      labelFormatter={(label) => `${label}`}
                      contentStyle={{
                        borderRadius: 16,
                        border: "1px solid #e2e8f0",
                        boxShadow: "0 8px 30px rgba(15, 23, 42, 0.08)",
                      }}
                    />
                    <Legend />
                    <Bar dataKey="원금" stackId="asset" radius={[6, 6, 0, 0]} fill="#94a3b8" />
                    <Bar dataKey="수익" stackId="asset" radius={[6, 6, 0, 0]} fill="#2563eb" />
                    {useRealValue ? <Bar dataKey="실질자산" fill="#10b981" hide /> : null}
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </section>

            <section className="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
              <div className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <h2 className="text-base font-bold text-slate-900">연차별 상세표</h2>
                  <p className="mt-1 text-sm text-slate-500">원금, 수익, 총자산을 연도별로 확인할 수 있습니다.</p>
                </div>
              </div>

              <div className="mt-4 overflow-x-auto">
                <table className="min-w-full border-separate border-spacing-0 overflow-hidden rounded-2xl border border-slate-200">
                  <thead className="bg-slate-50 text-left text-sm text-slate-600">
                    <tr>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">연차</th>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">나이</th>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">누적 원금</th>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">누적 수익</th>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">총자산</th>
                      <th className="border-b border-slate-200 px-4 py-3 font-semibold">실질가치</th>
                    </tr>
                  </thead>
                  <tbody className="bg-white text-sm text-slate-700">
                    {simulation.map((row) => (
                      <tr key={row.year}>
                        <td className="border-b border-slate-100 px-4 py-3">{row.year}년</td>
                        <td className="border-b border-slate-100 px-4 py-3">{row.age}세</td>
                        <td className="border-b border-slate-100 px-4 py-3">{formatMoney(row.principal)}</td>
                        <td className="border-b border-slate-100 px-4 py-3 text-blue-600">{formatMoney(row.profit)}</td>
                        <td className="border-b border-slate-100 px-4 py-3 font-semibold text-slate-900">{formatMoney(row.total)}</td>
                        <td className="border-b border-slate-100 px-4 py-3">{formatMoney(row.realTotal)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          </div>
        </div>

        <section className="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <div className="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 className="text-base font-bold text-slate-900">복리 투자 참고표</h2>
              <p className="mt-1 text-sm text-slate-500">
                월 투자금 100만원 기준으로 기간과 수익률에 따라 얼마나 달라지는지 빠르게 비교할 수 있습니다.
              </p>
            </div>
            <div className="flex flex-wrap gap-2">
              {quickMonthlyAmounts.map((amount) => (
                <span key={amount} className="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">
                  {formatMoney(amount)}
                </span>
              ))}
            </div>
          </div>

          <div className="mt-4 overflow-x-auto">
            <table className="min-w-full border-separate border-spacing-0 overflow-hidden rounded-2xl border border-slate-200">
              <thead className="bg-slate-50 text-left text-sm text-slate-600">
                <tr>
                  <th className="border-b border-slate-200 px-4 py-3 font-semibold">투자 기간</th>
                  {referenceReturns.map((rate) => (
                    <th key={rate} className="border-b border-slate-200 px-4 py-3 font-semibold">
                      연 {rate}%
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody className="bg-white text-sm text-slate-700">
                {referenceTable.map((row) => (
                  <tr key={row.year}>
                    <td className="border-b border-slate-100 px-4 py-3 font-semibold text-slate-900">{row.year}년</td>
                    {referenceReturns.map((rate) => (
                      <td key={rate} className="border-b border-slate-100 px-4 py-3">{row[`r${rate}`]}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section className="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 className="text-base font-bold text-slate-900">계산 안내</h2>
          <ul className="mt-4 space-y-2 text-sm leading-6 text-slate-600">
            <li>현재 자산과 월 투자금이 매달 동일한 수익률로 복리 성장한다고 가정했습니다.</li>
            <li>연 투자금 증가율을 넣으면 매년 월 투자금이 같은 비율만큼 증가합니다.</li>
            <li>실질가치는 물가상승률을 반영해 오늘의 구매력 기준으로 환산한 값입니다.</li>
            <li>실제 수익률은 시장 상황, 세금, 수수료, 환율 등에 따라 달라질 수 있습니다.</li>
          </ul>
        </section>
      </div>
    </main>
  );
}

function InputCard({
  label,
  value,
  onChange,
  suffix,
}: {
  label: string;
  value: string;
  onChange: (value: string) => void;
  suffix?: string;
}) {
  return (
    <label className="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
      <div className="flex items-center justify-between gap-3">
        <span className="text-xs font-semibold text-slate-500">{label}</span>
        {suffix ? <span className="text-xs text-slate-400">{suffix}</span> : null}
      </div>
      <input
        value={value}
        onChange={(e) => onChange(e.target.value)}
        inputMode="numeric"
        className="mt-2 w-full border-0 bg-transparent p-0 text-base font-bold text-slate-900 outline-none placeholder:text-slate-300"
      />
    </label>
  );
}

function RangeCard({
  label,
  value,
  onChange,
  min,
  max,
  step,
  suffix,
}: {
  label: string;
  value: number;
  onChange: (value: number) => void;
  min: number;
  max: number;
  step: number;
  suffix?: string;
}) {
  return (
    <div className="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
      <div className="flex items-center justify-between gap-3">
        <span className="text-xs font-semibold text-slate-500">{label}</span>
        <span className="text-sm font-bold text-slate-900">
          {value}
          {suffix}
        </span>
      </div>
      <input
        type="range"
        min={min}
        max={max}
        step={step}
        value={value}
        onChange={(e) => onChange(Number(e.target.value))}
        className="mt-3 h-2 w-full cursor-pointer appearance-none rounded-lg bg-slate-200"
      />
    </div>
  );
}

function ResultCard({
  title,
  value,
  accent,
}: {
  title: string;
  value: string;
  accent: "blue" | "green" | "violet" | "slate" | "indigo";
}) {
  const accentMap = {
    blue: "bg-blue-50 text-blue-700 border-blue-100",
    green: "bg-emerald-50 text-emerald-700 border-emerald-100",
    violet: "bg-violet-50 text-violet-700 border-violet-100",
    slate: "bg-slate-50 text-slate-700 border-slate-200",
    indigo: "bg-indigo-50 text-indigo-700 border-indigo-100",
  } as const;

  return (
    <div className={`rounded-2xl border p-4 ${accentMap[accent]}`}>
      <p className="text-xs font-semibold opacity-80">{title}</p>
      <p className="mt-2 text-xl font-black tracking-tight">{value}</p>
    </div>
  );
}
